:root {
	--header-coupon-bg: {{settings.greenweave_header_coupon_bg}};
--header-coupon-light: {{settings.greenweave_header_coupon_highlight}};
--header-coupon-text: {{settings.greenweave_header_coupon_text}};
--header-coupon-border: {{settings.greenweave_header_coupon_border}};
--header-coupon-btn-bg: {{settings.greenweave_header_coupon_btn_bg}};
--header-coupon-btn-color: {{settings.greenweave_header_coupon_btn_color}};
}
$bg: {{settings.greenweave_header_color_bkg_sb}};
$colorText: {{settings.greenweave_header_color_text_sb}};
$colorBoder: {{settings.greenweave_header_color_border}};
$colorHdHover: {{settings.greenweave_header_color_text_hover}};
.greenweave-sitenav-wrapper{
  .lazy-img__prod,.lazy-img__100 {padding-bottom: 100%;}
.lazy-img__100 .boxlazy-img__aspect {padding: 15px;}
.lazy-img-cb {
	padding-bottom: 100%;
	display: block;
	height: 0;
	position: relative;
	img {
		position: absolute;
		top: 50%;left: 50%;
		display: block;
		object-fit: contain;
		transform: translate(-50%, -50%);
	}
}
.boxlazy-img {
	&__insert {
		position: relative;
		height: 0;
		display: block;
		width: 100%;
	}
	&__aspect {
		position: absolute;left: 0;right: 0;top: 0;bottom: 0;
		display: flex;align-items: center;justify-content: center;
		img{
			position: absolute; top: 50%; left: 50%;
			display: block;  max-height: 100%;object-fit: contain;transform: translate(-50%, -50%);
		}
		iframe{
			max-height:100%;display:block;    transition: 0s;
			position: absolute;	width: 100%;height: 100%;left: 0;top: 0;border: none;overflow: hidden;
			/*font-family: "blur-up: auto", "object-fit: contain";	-o-object-fit: contain;	object-fit: contain;*/
		}
	}
}
}

.greenweave-sitenav-cart{
	.greenweave-cart-view-scroll{ 
		.greenweave-mini-cart__item{
			position: relative; border-bottom: 1px dotted $colorBoder;
			display: -webkit-box;display: -ms-flexbox;display: flex;
			padding: 12px 0;
			&:last-child{border-bottom:0;}
			td{padding-top:12px;padding-bottom:12px;position: relative; vertical-align: middle}
			.greenweave-mini-cart__left{width:90px;padding-right: 15px;max-width: none;text-align:center;
				img{display: block;border: 1px solid #ededed;}
				.greenweave-mnc-gift{
					position: absolute;top: 5px;left: 0px;display: block;padding: 4px;
					background:#ffffff;border: 1px solid #ededed;
					width: 24px;height: 24px;text-align: center;line-height: 24px;border-radius: 50%;
					img{border:0;margin: auto;}
				}
			}
			.greenweave-mini-cart__right{
				padding-left:5px;flex: 0 0 calc(100% - 90px);max-width: calc(100% - 90px);
				.greenweave-mini-cart__title{
					.greenweave-mnc-title{
						display: block;font-size: 14px;
						font-weight: 600;padding-right:28px;
						text-transform: uppercase;
					}
					.greenweave-mnc-variant{display: block;font-size: 13px;margin:0px 0 7px;color: rgba($colorText, 0.6);}
					.greenweave-mnc-note {
						font-size: 12px;
					}
				}
				.greenweave-mini-cart__quantity {
					.greenweave-qty-value{
						float: left;
						width: 28px;
						height: 28px;
						background: #fff;
						text-align: center;
						font-size: 13px;
						line-height: 1;
						color: #252a2b;
						border: 0;
						border-top: 1px solid #f9f9f9;
						border-bottom: 1px solid #f9f9f9;
						padding: 0;
						&:focus{outline:none;}
					}
					.greenweave-qty-btn {
						float: left;
						font-weight: 500;
						font-size: 18px;
						padding: 0;
						height: 28px;width: 28px;
						text-align: center;
						background: #f9f9f9;color:$colorText;
						border: 1px solid #f9f9f9;
						outline: none;-webkit-appearance: none;-moz-appearance: none;-o-appearance: none;appearance: none;
						display: flex;
						align-items: center;
						justify-content: center;
						svg {display: block;width: 10px;height: 100%;margin: 0 auto;}
					}	
				}
				.greenweave-mini-cart__price {display: flex;display: -ms-flex;justify-content: flex-end;-ms-justify-content: flex-end;flex-direction: column;-ms-flex-direction: column;}
				.greenweave-mini-cart__price .greenweave-mnc-price{
					display: block;text-align: right;
					float: right;line-height: 26px;
					font-weight: 600;color:$colorText;
				}
				.greenweave-mini-cart__price .greenweave-mnc-ori-price{text-align:right;float:right;}
				.greenweave-mini-cart__remove{position: absolute;right:0px;top:10px; width: 20px;height: 20px;line-height: 20px;text-align: center;}
				.greenweave-mini-cart__remove a{width: 20px;height: 20px;line-height: 20px;display: block;color:$colorText;}
				.greenweave-mini-cart__remove a svg{width: 12px;fill: $colorText;}
			}
		}
		.greenweave-mini-cart__empty{
			.greenweave-svgico-mini-cart {padding-top: 20px;padding-bottom:20px;position: relative;text-align: center;color: $colorText; }
			.greenweave-svgico-mini-cart svg {stroke:$colorHdHover;width: 50px;height: 50px;margin: auto;}
		}
	}
	.greenweave-cart-view-line { clear: both;width: 100%;border-top:1px solid  $colorBoder;	margin:0 0 5px;}
	.greenweave-cart-view-total {
		.greenweave-total-price {display: -webkit-box;display: -ms-flexbox;display: flex;align-items: center;justify-content: space-between;}
		.greenweave-mnc-total{font-size: 16px;font-weight: 500; color: $colorText;}
		#greenweave-total-view-cart{ font-weight: 600;font-size: 18px; color: red; text-align: right;}
		.greenweave-linktocheckout {margin:5px 0 5px;padding: 10px 10px;font-size: 12px;font-weight: 600;text-align: center;text-transform: uppercase; width: 100%;background-color:#ff0000;border-color:#ff0000;color:#ffffff;display: block;}
		.greenweave-linktocheckout.disabled {pointer-events: none;opacity: 0.7;background: #151515;border-color: #151515;}
		.greenweave-linktocheckout:before {background-color:#ff0000;}
		.greenweave-linktocart {display: block;font-size: 14px;text-decoration: underline;color: $colorHdHover;}
		.greenweave-linkcoupon {border:0;font-size:14px;text-decoration: underline;color: $colorHdHover;cursor: pointer;}
		.greenweave-action-link {display: flex;justify-content: space-between;}
		.greenweave-action-link-empty {display: none;}
		.greenweave-summary-alert {
			display: none;
			background-color: #fee3e8;
			border: 1px solid #fdd0d8;
			color: #d20909;
			font-size: 13px;
			padding: 10px 15px;
			margin: 10px 0;
			text-align: left;
		}
	}
	.greenweave-cart-shipping {
		.greenweave-shipping-title {font-size: 16px;font-weight: 400;color: #666666;letter-spacing: 0.5px;min-height: 30px;}
		.greenweave-price {font-weight: 600;color:#ff2c26;}
		.greenweave-free-ship {
			text-transform: uppercase;
			font-weight: 600;
		}
		&__bar {
			height: 8px;
			width: 100%;
			background-color: #e9e9e9;
			border-radius: 5px;
			margin: 15px 0 10px;
			position: relative;
			span {
				background-color: #ffbc11;
				width: 0;
				border-radius: 5px;
				transition: width .4s ease-in-out;
				display: block;
				height: 100%;
				position: relative;
				.icon {
					width: 30px;height: 30px;
					display: inline-flex;align-items: center;justify-content: center;
					border-radius: 50%;
					position: absolute;
					top: 3px;right: 14px;
					transform: translate(50%,-50%);
					font-weight: 700;
					content: "";
					font-size: 12px;
					color: #ffbc11;
					border: 1px solid #ffbc11;
					background: currentColor;
					svg {fill: #fff;}
				}
			}
		}
		&.greenweave-cart-shipping-free {
			.greenweave-cart-shipping__bar .greenweave-shipping-bar {background-color:#3d9851;}
			.greenweave-cart-shipping__bar .greenweave-shipping-bar .icon {background-color:#3d9851;border-color:#3d9851;color: #3d9851;}
		}
	}
	&.greenweave-cart-empty {
		.greenweave-cart-shipping {display: none;}
		.greenweave-sitenav-footer {display: none;}
		.greenweave-action-link-empty {display: flex;justify-content: space-around;margin-top: 10px;}
		.greenweave-linkreturn, .greenweave-linkcoupon {border:0;font-size:14px;text-decoration: underline;color: $colorHdHover;cursor: pointer;}
	}
	@media(min-width:992px){
		.greenweave-mini-cart__empty .greenweave-svgico-mini-cart {padding: 10px 0 5px;}
		.greenweave-mini-cart__empty .greenweave-svgico-mini-cart p {font-size: 18px;}
		.greenweave-cart-view-scroll::-webkit-scrollbar {width:4px;	height: 3px; }
		.greenweave-cart-view-scroll::-webkit-scrollbar-track {-webkit-border-radius:2px;border-radius: 2px;}
		.greenweave-cart-view-scroll::-webkit-scrollbar-thumb {
			-webkit-border-radius:2px;border-radius:2px;background:#e1e3e4;
			-webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3); 
		}
		.greenweave-cart-view .greenweave-cart-view-scroll::-webkit-scrollbar-thumb:window-inactive {background:#e1e3e4; }
	}
	@media(max-width:991px){
		.greenweave-mini-cart__empty .greenweave-svgico-mini-cart {padding: 0 0 5px;}
		.greenweave-cart-view-scroll {
			.greenweave-mini-cart__item {
				.greenweave-mini-cart__right .greenweave-mini-cart__title {margin-bottom:0;}
			}
		}
		.greenweave-cart-view-coupon {display: none;}
		.greenweave-sitenav-header .greenweave-cart-shipping {margin-top: 15px;}
		&.greenweave-cart-empty .greenweave-action-link-empty {flex-direction: column;}
		&.greenweave-cart-empty .greenweave-action-link-empty a {margin-bottom: 8px;}
	}
	@media(max-width:575px){
		.greenweave-cart-shipping .greenweave-free-ship {display: block;}
		.greenweave-cart-shipping.greenweave-cart-shipping-free .greenweave-free-ship {display: inline-block;}
	}
	@media(max-width:360px){
		.greenweave-cart-view-scroll .greenweave-mini-cart__item .greenweave-mini-cart__right .greenweave-mini-cart__price {display: block;}
		.greenweave-cart-view-scroll .greenweave-mini-cart__item .greenweave-mini-cart__right .greenweave-mini-cart__price .greenweave-mnc-price {width: 100%;text-align: left;margin-top: 5px;}
	}
}

/*======== coupon -- popover ==========*/

.greenweave-coupon-popover{			
	margin-left: 15px;
	margin-right: 15px;
	max-width: 400px;
	font-family: inherit;
	font-size: 13px;
	z-index: 500;
	padding: 0;
	border: 0;
	border-radius: 8px;
	background: #ffffff;
	box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 18px;
	.popover-header{
		display:none;		
		text-align: center; background: #ffffff; border-radius: 16px 16px 0 0; 
		font-size: 20px;padding: 15px 10px; font-weight: 600;
		width: 100%; color:#242424; border-bottom: 0;
	}
	.popover-body{
		width: 360px;
		border-radius: 8px;	background: #ffffff;padding: 24px 0px;
		box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 18px;
	}
	.popover-content__coupon{
		font-size:13px;color:#000000;
		.dfex-txt{
