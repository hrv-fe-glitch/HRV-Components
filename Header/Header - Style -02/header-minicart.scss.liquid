				}
			}
			&--3{
				width:100%;
				ul{list-style-type: disc;margin-bottom:0;margin-top:0;margin-left:16px;}
				ul li{list-style-position: outside;}
				ul li+li{margin-top:3px;}
				ul li::marker { color: #000;}
			}
			&--cta{
				width:100%;
				.btn-popover{
					display: block;	width: 100%;
					padding: 0px 12px;font-size: 13px;
					height: 44px;	line-height: 42px;
					border-radius: 4px;font-weight: 500;
					color: #fff;background: red; border: 1px solid red;
					&+.btn-popover{margin-top:12px;	color:red;background: #fff;}
				}
			}
		}
		.dfex-bkg:nth-child(2n+1) {background-color: rgb(250, 250, 250);}

	}
	&.top>.arrow{border-top-color:#ffffff}
	&.bottom>.arrow{border-bottom-color:#ffffff}
	&.left>.arrow{border-left-color:#ffffff}
	&.right>.arrow{border-right-color:#ffffff}
	&.bs-popover-top>.arrow::before {border-top-color:#ffffff;}
	@media(max-width:767px){
		&{
			position: fixed!important;z-index: 1010;	width: 100%;max-width:100%;
			left: 0!important;right: 0!important;top: initial!important;bottom: 0;margin: 0;
			-webkit-transform: translateY(100%)!important;transform: translateY(100%)!important;
			transition: all 0.4s cubic-bezier(0.645, 0.045, 0.355, 1);  
			background: #ffffff;box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 18px;border-radius: 16px 16px 0 0; 					
			&.fade.show{-webkit-transform: translateY(0)!important;transform: translateY(0)!important;}
		}
		.popover-header{
			display:block;
			&:before {
				content: "";position: absolute;
				left: calc(50% - 24px);top: -14px;
				width: 48px;height: 6px;border-radius: 3px;	background: #ffffff;
			}
		}
		.popover-body{margin-left:0;margin-right:0;border-radius:0; box-shadow: none;padding: 0;width:100%;}
		.arrow{display:none;}
		.popover-content__coupon{
			.dfex-txt{
				padding: 12px 20px;
				&.dfex-none{display: -ms-flexbox; display: -webkit-flex; display: flex;}
			}
		}
	}
}	
@media(max-width:767px){
	.modal-coupon--backdrop{
		position: fixed;	background-color: rgba(0, 0, 0, 0.5); top: 0; left:0;right:0;height:100%;z-index:999;
		display:none;opacity: 0;visibility: hidden;transition: all 0.3s cubic-bezier(0.645, 0.045, 0.355, 1);
	}
	.modal-coupon--backdrop.js-modal-show {	display:block;opacity: 1;visibility: visible;pointer-events: auto;}
}

.greenweave-coupon-initial{	
  .lazy-img__prod,.lazy-img__100 {padding-bottom: 100%;}
.lazy-img__100 .boxlazy-img__aspect {padding: 15px;}
.lazy-img-cb {
	padding-bottom: 100%;
	display: block;
	height: 0;
	position: relative;
	img {
		position: absolute;
		top: 50%;left: 50%;
		display: block;
		object-fit: contain;
		transform: translate(-50%, -50%);
	}
}
.boxlazy-img {
	&__insert {
		position: relative;
		height: 0;
		display: block;
		width: 100%;
	}
	&__aspect {
		position: absolute;left: 0;right: 0;top: 0;bottom: 0;
		display: flex;align-items: center;justify-content: center;
		img{
			position: absolute; top: 50%; left: 50%;
			display: block;  max-height: 100%;object-fit: contain;transform: translate(-50%, -50%);
		}
		iframe{
			max-height:100%;display:block;    transition: 0s;
			position: absolute;	width: 100%;height: 100%;left: 0;top: 0;border: none;overflow: hidden;
		}
	}
}
}
.greenweave-coupon-initial {
	.greenweave-listCoupon {
		background: #fff;
		display: flex; display: -ms-flex; flex-wrap: wrap;-ms-flex-wrap: wrap;
		margin-left: -7px;margin-right: -7px;
	}
	.greenweave-title-coupon h2 {
		font-size: 16px;
		margin: 0 0 8px;
	}
	.greenweave-coupon-item {
		padding-left: 7px;padding-right: 7px;
		&__inner {
			background: var(--header-coupon-bg);
			display: flex;display: -ms-flex;
			border-radius: 15px;
			height: 100%;
			border: 1px solid rgba(0, 0, 0, 0.08);
		}
		&__left {
			flex: 0 0 30%;-ms-flex: 0 0 30%;
			max-width: 30%;
			position: relative;
			border-right: 1px dashed var(--header-coupon-border);
			padding: 8px;
			&:after, &:before {
				content: "";
				width: 20px;height: 10px;
				right: -10px;
				position: absolute;
				background: #fff;
				z-index: 1;
				border: 1px solid rgba(0, 0, 0, 0.08);
			}
			&:after {top: -1px;border-top: 0;border-bottom-left-radius: 10px;border-bottom-right-radius: 10px;}
			&:before {bottom: -1px;border-bottom: 0;border-top-left-radius: 10px;border-top-right-radius: 10px;}
			.greenweave-cp-img {
				background: var(--header-coupon-light);
				border-radius: 10px;
			}
		}
		&__right {
			flex: 0 0 70%;
			max-width: 70%;
			position: relative;
			display: flex;display: -ms-flex;
			flex-direction: column;-ms-flex-direction: column;
			justify-content: space-between;-ms-justify-content: space-between;
			padding: 10px;
			color: var(--header-coupon-text);
			.greenweave-cp-icon {
				background: transparent;
				border: 0;
				outline: none;
				cursor: pointer;
				position: absolute;
				top: 5px;
				right: 5px;
				padding: 5px;
			}
			.greenweave-cp-top {
				padding-bottom: 12px;padding-right: 24px;
				h3 {
					margin: 0 0 2px;
					font-size: 14px;
					font-weight: 700;
					color: var(--header-coupon-text);
				}
				p {font-size: 12px;font-weight: 500;margin: 0;}
			} 
			.greenweave-cp-bottom {
				display: flex;display: -ms-flex;
				justify-content: space-between;-ms-justify-content: space-between;
				.greenweave-cp-bottom-btn {display: flex;display: -ms-flex;}
				p {font-size: 10px;margin: 0;}
				p strong {letter-spacing: 0.4px;font-size: 11px;}
			}
			.greenweave-cp-btn {
				padding: 3px 6px;
				font-size: 10px;
				min-width: 92px;
				letter-spacing: 0.5px;
				border-radius: 20px;
				margin-top: auto;
        border: none;
        outline: none;
        background: var(--header-coupon-btn-bg);
        color: var(--header-coupon-btn-color);
			}
		}
	}
	.list-coupon-slide {padding-bottom: 15px;}
	.swiper-pagination {bottom: 0;}
	&.greenweave-coupon-second {
		.greenweave-coupon-item__inner {
			position: relative;
			border:0;border-radius: 0;
			border-top: 1px solid var(--header-coupon-border);
			border-bottom: 1px solid var(--header-coupon-border);
			&:before, &:after {
				content: "";
				position: absolute;
				top: 0;
				bottom: 0;
				width: 10px;
				height: 100%;
			}
			&:before {
				left: 0;
				background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, #fff 0, #fff 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 0px/1px 100% no-repeat, radial-gradient(circle at 0px 8px, #fff, #fff 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
			}
			&:after {
				right: 0;
				background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, #fff 0, #fff 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 9px/1px 100% no-repeat, radial-gradient(circle at 8px 8px, #fff, #fff 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
			}
		}
		.greenweave-coupon-item__left {display: none;}
		.greenweave-coupon-item__right {
			-ms-flex: 0 0 100%;flex: 0 0 100%;
			max-width: 100%;
			padding: 10px 15px;
			.greenweave-cp-top {padding-bottom: 20px;}
		}
	}
	&.bgWhite {
		.greenweave-coupon-item__inner:before {
			background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, transparent 0, transparent 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 0px/1px 100% no-repeat, radial-gradient(circle at 0px 8px, transparent, transparent 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
		}
		.greenweave-coupon-item__inner:after {
			background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, transparent 0, transparent 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 9px/1px 100% no-repeat, radial-gradient(circle at 8px 8px, transparent, transparent 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
		}
		.greenweave-coupon-item__left:after, .greenweave-coupon-item__left:before {
			background: #fff;
		}
	}
	@media(max-width: 1199px) and (min-width: 768px){
		.greenweave-coupon-item {margin-bottom: 14px;}
	}
	@media(max-width: 767px){
		.greenweave-listCoupon {
			flex-wrap: nowrap;-ms-flex-wrap: nowrap;
			margin-left: -15px; margin-right: -15px;padding-left: 15px;
			overflow-x: scroll;-webkit-overflow-scrolling: touch;
			transition: transform 0.25s ease 0s;
			&::-webkit-scrollbar {display: none;}
			.greenweave-coupon-item {
				padding-left: 0; padding-right: 15px; margin-bottom: 0;float: none;
				display: inline-block;flex: 0 0 90%;-ms-flex: 0 0 94%;max-width: 90%;
			}
		}
	}
}
