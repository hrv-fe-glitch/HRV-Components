			var line = $(this).parents('.greenweave-mini-cart__item').index() + 1;
			var currentQty = parseInt($(this).parents('.greenweave-mini-cart__item').find('input').val());
			var newQty = currentQty + 1;
			$(this).parents('.greenweave-mini-cart__item').find('input').val(newQty);
		});

