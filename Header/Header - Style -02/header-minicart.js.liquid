
//Delay action
function GreenWeave_delayTime (func, wait) {
	return function() {
		var that = this,
				args = [].slice(arguments);
		clearTimeout(func._throttleTimeout);
		func._throttleTimeout = setTimeout(function() {
			func.apply(that, args);
		}, wait);
	};
}
GreenWeave.MiniCart = {
		init: function() {
			var that = this;
      that.GreenWeave_showModalCoupon();
      that.GreenWeave_slideCouponModal();
      that.GreenWeave_copyCodeModalCoupon();
      that.GreenWeave_updateMiniCart();
		},
  GreenWeave_showModalCoupon: function(){
		$(document).on('click', '.greenweave-sitenav-cart .greenweave-linkcoupon', function(e){ 
			$('#greenweave-modal-coupon').modal('show');
		})
	},
	GreenWeave_slideCouponModal: function(){
		var swiper = new Swiper("#greenweave-modalCoupon", {
			slidesPerView: 1,
			spaceBetween: 12,
			grid: {
				rows: 2,
				fill: "row",
			},
			pagination: {
				el: ".swiper-pagination",
				clickable: true,
			},
		});
	},
  GreenWeave_copyCodeModalCoupon: function(){
		$(document).on('click', '.greenweave-coupon-item .greenweave-cp-btn', function(e){ 
			e.preventDefault();	
			$('.greenweave-coupon-item .greenweave-cp-btn').html('Sao chép mã').removeClass('disabled');
			var copyText = $(this).attr('data-coupon');
			var dummy = $('<input class="greenweave-copy-coupon-text-hide">').val(copyText).appendTo('.greenweave-coupon-initial').select();
			dummy.focus();
			document.execCommand('copy');
			$('.greenweave-copy-coupon-text-hide').remove();
			$(this).html('Đã sao chép').addClass('disabled');
		});
	},
