<script>
  var langObj = {}
  function changeLanguage (lang,lang_flag) {
    if (langObj[lang]) {
      $(".js-translate .svg-flag").html(lang_flag);
      $(".language-text").html(langObj[lang]);
      $(`.js-language-select[data-lang='${lang}']`).addClass('d-none').siblings().removeClass("d-none");
    }
  }
  $("body").on("click",'.js-language-select',function(e){
    e.preventDefault();
    const lang = $(this).attr('data-lang'), 
          lang_title = $(this).attr('data-title'),
          lang_flag = $(this).find('.flag').html();
    doGTranslate("vi|"+lang);
    localStorage.setItem("selectedLang", lang);
    localStorage.setItem("selectedLangFlag", lang_flag);
    changeLanguage(lang,lang_flag)
  })
  $(window).ready(function(){
    $(".js-language-select").each(function(){
      var key = $(this).attr("data-lang");
      var value = $(this).attr("data-title");
      langObj[key] = value;
    })
    var currentLang = localStorage.getItem("selectedLang"),
        currentLangFlag = localStorage.getItem("selectedLangFlag");
    
    if (currentLang) {
      document.documentElement.setAttribute("lang", currentLang);
    }
    changeLanguage(currentLang,currentLangFlag);
  })
</script>