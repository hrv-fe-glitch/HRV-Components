@keyframes smoothScroll {
	0% {
		transform: translateY(-90px); }
	100% {
		transform: translateY(0px); } }
/*--------------------------------------------------------------------------------
SIDEBAR MAIN
--------------------------------------------------------------------------------*/
.parkrise-sidebar-main{
	.parkrise-sitenav-wrapper{
		position: fixed;
		top: 0;
		bottom: 0;
		z-index: 999;
		background: transparent;
		&.parkrise-sitenav-right{
			right: 0;
			.parkrise-sitenav-inner{
				right: 0;
				-webkit-transform: translateX(120%);transform: translateX(120%);
				-webkit-transition: transform 0.35s ease,right 0.25s ease, visibility 0s;transition: transform 0.35s ease,right 0.25s ease, visibility 0s;
			}
		}
		&.parkrise-sitenav-left{
			left: 0;
			.parkrise-sitenav-inner{
				left: 0;
				-webkit-transform: translateX(-100%);transform: translateX(-100%);
				-webkit-transition: transform 0.35s ease,left 0.25s ease, visibility 0s;transition: transform 0.35s ease,left 0.25s ease, visibility 0s;
			}
		}
		.parkrise-sitenav-inner{
			margin: 0 auto;
			max-width: 480px;
			position: absolute;
			top: 0;
			bottom: 0;
			background: $bg;
			background-clip: padding-box;
			display: flex;
			flex-direction: column;
			&:after{
				content: "";
				position: absolute;
				width: 100%;
				height: 100%;
				background: #fff;
				z-index: 1;
				opacity: 1;
				visibility: visible;
			}
		}
	}
	&.parkrise-is-show-right{
		.parkrise-sitenav-wrapper.parkrise-show{
			left: 0 !important;
			-webkit-transition-delay: 0s;
			transition-delay: 0s;
		}
		.parkrise-sitenav-wrapper.parkrise-show .parkrise-sitenav-inner{
			right: 0;width: 85%;
			-webkit-transform: translateX(0);transform: translateX(0);
			-webkit-transition-delay: 0.1s;transition-delay: 0.1s;
			-webkit-transition-duration: 0.3s;transition-duration: 0.3s;
			&:after{visibility: hidden;opacity: 0;}
		}
		.parkrise-sitenav-wrapper.parkrise-show .parkrise-sidebar-overlay{opacity:1;visibility: visible;}
	}
	&.parkrise-is-show-left{
		.parkrise-sitenav-wrapper.parkrise-show{
			right: 0 !important;
			-webkit-transition-delay: 0s;
			transition-delay: 0s;
		}
		.parkrise-sitenav-wrapper.parkrise-show .parkrise-sitenav-inner{
			left: 0;width: 85%;
			-webkit-transform: translateX(0);transform: translateX(0);
			-webkit-transition-delay: 0.1s;transition-delay: 0.1s;
			-webkit-transition-duration: 0.3s;transition-duration: 0.3s;
			&:after{visibility: hidden;opacity: 1;}
		}
