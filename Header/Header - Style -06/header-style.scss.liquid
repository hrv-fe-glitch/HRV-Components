$bg: {{settings.parkrise_header_color_bkg_sb}};
$colorText: {{settings.parkrise_header_color_text_sb}};
$colorBoder: {{settings.parkrise_header_color_border}};
$colorHd: {{settings.parkrise_header_color_text}};
$bgHd: {{settings.parkrise_header_color_bkg}};
$colorHdHover: #FFFFFF;
$colorHdHover2: {{settings.parkrise_header_color_text_hover}};
$colorLive: {{settings.parkrise_header_live_color}};

.parkrise-mainHeader--height {
   position: fixed;
  width: 100%;
  left: 0;
  top: 0px;
  z-index: 999;
  padding: 15px 0;
  transition: .3s all;
  @media (max-width: 992px) {
    //top: 79px;
    padding: 0px 0;
  }
  &.is-scrolled {
    top: 0!important;
  }
  &:after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(180deg, var(--header-background-1) 0%, transparent 100%);
    pointer-events: none;
  }
}
              
/*========Header========*/
.parkrise-mainHeader {
	width:100%;
	transition:-webkit-box-shadow 0.3s ease-in-out;
	transition: box-shadow 0.3s ease-in-out;
	transition: box-shadow 0.3s ease-in-out, -webkit-box-shadow 0.3s ease-in-out;
	//background: $bgHd;
  color: $colorHd;
  .menu-decoration__decoration {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
  }
  .menu-decoration__decoration-border-part {
    visibility: visible;
    opacity: 1;
    transition-duration: var(--timing-base);
    transition-delay: 0s, 0s, var(--timing-base), var(--timing-base);
    transition-property: stroke-dasharray, stroke-dashoffset, opacity, visibility;
  }
  .menu-decoration__decoration-border {
    width: calc(100% - 2px);
    height: calc(100% - 2px);
    color: var(--menu-decoration-border-color);
  }
  .menu-decoration__decoration-border-part {
    visibility: hidden;
    opacity: 0;
    width: calc(100% - 2px);
    height: calc(100% - 2px);
    color: var(--menu-decoration-border-part-color);
  }
  .menu-decoration.is-active .menu-decoration__decoration-border-part {
    visibility: visible;
    opacity: 1;
    transition-duration: var(--timing-base);
    transition-delay: 0s, 0s, var(--timing-base), var(--timing-base);
    transition-property: stroke-dasharray, stroke-dashoffset, opacity, visibility;
  }
	.parkrise-flex-header{
		display: -webkit-flex;display: flex;
		-webkit-align-items: center;align-items: center;
		-webkit-flex-flow: row nowrap;flex-flow: row nowrap;
		-webkit-justify-content: space-between;justify-content: space-between;
    position: relative;
    z-index: 10;
		&>[class*='parkrise-header-wrap-'] {
			padding:0px 10px;
		}
	} 
	.parkrise-header-left{display: flex;align-items: center;gap: 40px;}
	.parkrise-header-right{
		display: flex;
		align-items: center;
		justify-content: end;
		gap: 15px;
		.parkrise-header-hotline{
			.hotline{
				display: flex;
				align-items: center;
				gap: 10px;
				font-size: 20px;
				.icon {
					width: 40px;
					height: 40px;
					line-height: 40px;
					border-radius: 50%;
					display: inline-block;
					text-align: center;
					background: rgba($colorHdHover, 0.1);
					color: $colorHdHover;
				}
			}
		}
	}
	.parkrise-header-wrap-menu{
    flex: 1;
		.parkrise-navbar-mainmenu{
      position: relative;
      display: inline-flex;
      padding: 10px 8px;
      border-radius: calc(var(--global-border-radius) / 2);
      z-index: 10;
    }  
		.parkrise-menuList-main{
      margin:0;
      justify-content: start;
      display: inline-flex;
      flex-wrap: wrap;
      border-radius: calc(var(--global-border-radius) / 4);
      backdrop-filter: blur(0px);
        background-color: $bgHd;
        transition: .3s all;
			&>li {
				display: inline-block;padding: 10px 4px;position: relative;
				&>a {
					position: relative;z-index: 2;align-items: center;
					display: flex;gap: 5px;border-radius: 4px;
					width: 100%;font-size: 15px;overflow: hidden;
          line-height: 1.4;padding: 8px 12px;
					-webkit-transition:none;transition:none;
					color: $colorHd;font-weight: bold;
					svg {
						display: inline-block;vertical-align: middle;margin-left: 0;fill: currentcolor;
						-webkit-transition:transform .2s;-moz-transition:transform .2s;	-o-transition:transform .2s;transition:transform .2s;
					}
          &:before {
            content: "";
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            border: 1px solid #FFF;
            background-color: transparent;
            transition: 0.4s ease all;
          }
				}
				&.active > a, &:hover>a,&.active:hover > a{
          
          &:before{
            opacity: 1;
          }
           > svg {
            opacity: 1;
            transform: rotate(180deg);
          }
				}
			}
			li.parkrise-has-submenu{
				.parkrise-menuList-submain {
					background: $bg;min-width:185px;	max-width:180%;
					position: absolute;z-index:99;top:150%;
					pointer-events: none; visibility: hidden; opacity: 0;
					-webkit-box-shadow: 0px 0px 3px rgba(0,0,0,0.15);	box-shadow: 0px 0px 3px rgba(0,0,0,0.15);
					-webkit-transition: all 0.3s ease;-o-transition: all 0.3s ease;transition: all 0.3s ease;
          border-radius: 12px;overflow: hidden;
				}
				.parkrise-menuList-submain ul.parkrise-menuList-submain {left: 100%;top:0;	}
				&:hover {
          > a {
            background: $bgHd;
            color: white;
          }
          &>.parkrise-menuList-submain {pointer-events: auto;visibility: visible;top: 100%;opacity: 1;}
        }
			}
			.parkrise-item-live{
				display: -webkit-flex;
				display: flex;
				.parkrise-header-box-live {
					.parkrise-btn-live{
						padding: 5px 12px 5px 20px;
						color: $colorLive;
						background: transparent;
						outline: none;
						border: none;
						position: relative;
						&:after{
							content: '';
							background: $colorLive;;
							width: 8px;
							height: 8px;
							position: absolute;
							left: 7px;
							top: calc(50% - 4px);
							border-radius: 50%;
							animation: pulselive 1.65s linear infinite;
						}
					}
				}
			}
			@media(max-width:1199px) and (min-width:992px){
				&>li >a{font-size: 13px;}
			}
		}
		.parkrise-menuList-submain{
			li{
				position: relative;
				&:not(:last-child){
					&:before{
						content: '';
						position: absolute;
						bottom: 0;
						left: 0;
						width: 100%;
						height: 1px;
						background: rgba($colorText, 0.1);
					}
				}
				a {
          padding: 16px 24px;text-align: left;display: block;font-size: 14px;font-weight: 400;color:$colorText;
          &:hover {
            background: rgba(158,158,158, 0.4);
            font-weight: 500;
          }
        }
				a svg {
					width: 15px;
					position: absolute;right: 15px;top: 50%;
					-ms-transform:translateY(-50%);
					-webkit-transform:translateY(-50%);
					transform:translateY(-50%);
					-webkit-transition: right 0.3s ease-in-out;
					-ms-transition:right 0.3s ease-in-out;
					transition: right 0.3s ease-in-out;
				}
			}
			li a:hover,li a:hover i{color: $colorHdHover;}
		}
	}
	.parkrise-header-wrap-logo{
    text-align: center;
    @media (max-width: 992px) {
      margin-right: auto;
      margin-left: auto;
    }
		h1,a {
			font-size: 26px;font-weight: 600;text-decoration: none;
			text-transform: uppercase;margin:0;color: $colorHd;
			white-space: initial;	overflow: hidden;
			-webkit-line-clamp: 1;-webkit-box-orient: vertical;
		}
	}
	.parkrise-header-wrap-action{
    padding: 13px 20px;
    border-radius: calc(var(--global-border-radius) / 4);
    background-color: $bgHd;
		.parkrise-header-action {
			position: relative;align-items: center;
			display: flex; display: -webkit-flex;
			justify-content: flex-end; -webkit-justify-content: flex-end;
			gap: 3px;
			.parkrise-header-action-item {
				align-self: center;
				.parkrise-header-action_text{
					&{position: relative;height: 100%;display: -ms-flexbox;display: -webkit-flex;display: flex;-webkit-align-items: center;-ms-align-items: center;align-items: center;}
					.parkrise-box-triangle {position: absolute;width: 24px;height:15px;top: 100%;z-index: 999;visibility: hidden;opacity: 0;left: 0;right: 0;margin: 0 auto;}
					.parkrise-box-triangle svg {-webkit-filter: drop-shadow(0 -3px 2px rgba(0, 0, 0, 0.12));filter: drop-shadow(0 -3px 2px rgba(0, 0, 0, 0.12));fill: $bg;}
					.parkrise-header-action__link {position: relative;display:block;font-size:13px;color:$colorHd;white-space: nowrap;}
					.parkrise-header-action__link .parkrise-box-icon,
					.parkrise-header-action__link .box-text{display: inline-block; vertical-align: middle;}
					.parkrise-header-action__link .box-text{padding-left:2px;}
					.parkrise-header-action__link .box-text .txtnw {font-size:11px;}
					.parkrise-header-action__link .box-text .txtbl{font-size:13px;display:block;font-weight: 500;}
					.parkrise-header-action__link .box-text .txt-overflow{white-space: nowrap;text-overflow: ellipsis; display: inline-block;vertical-align: middle;max-width: 115px; overflow: hidden;}
					.parkrise-header-action__link .box-text .fa{	display: inline-block;font-size: 16px;vertical-align: middle;	margin-left: 3px;}
					.parkrise-header-action__link .parkrise-box-icon{position: relative;width:32px;height:40px;text-align: center;}
					.parkrise-header-action__link .parkrise-box-icon svg:not(.icon-circle-decoration-border){width:22px;height:40px;fill: currentColor;}
					.parkrise-header-action__link .parkrise-box-icon svg.parkrise-svg-ico-account{width: 22px;}
					.parkrise-header-action__link .parkrise-box-icon svg.parkrise-svg-ico-search{width: 20px;}
					.parkrise-header-action__link .parkrise-box-icon .parkrise-box-icon--close{
						position: absolute;top: 0;left: 0;right:0;bottom:0;
						opacity: 0;visibility: hidden;    transform: scale(0.3);
						transition: opacity 0.35s ease-in-out, -webkit-transform 0.35s ease-in-out;
						transition: opacity 0.35s ease-in-out, transform 0.35s ease-in-out;
						transition: opacity 0.35s ease-in-out, transform 0.35s ease-in-out, -webkit-transform 0.35s ease-in-out;
						svg{width:18px}					
					}
					.parkrise-header-action__link .parkrise-box-icon .parkrise-count-holder{
						display: inline-block;vertical-align: top;
						background: $colorHd;color: #fff;
						font-size: 11px;text-align: center;
						position: absolute;left: 16px;top:-1px;padding: 0px 3px;
						min-width: 20px;height: 20px;	line-height: 20px;border-radius: 50%;
					}				
					.parkrise-header-action__link:hover svg.parkrise-svg-ico-search{-ms-transform:rotate(-5deg);	-webkit-transform:rotate(-5deg);transform: rotate(-5deg);}
				} 
				.parkrise-header-action_dropdown{
					position: absolute;top: calc(100% + 7px);  left: auto;right:-15px;z-index: 990;
					min-width: 280px;border-radius: 3px;
					color: $colorText;background: $bg;  border: solid 1px $colorBoder;
					box-shadow: 0 1px 5px 2px rgba(0, 0, 0, 0.1);
					visibility: hidden;opacity: 0;
					-webkit-transform: scale(0.9);transform: scale(0.9);
					transition: opacity 0.25s ease-in-out, visibility 0.25s ease-in-out, max-height 0s linear 0.25s, -webkit-transform 0.25s ease-in-out;
					transition: opacity 0.25s ease-in-out, transform 0.25s ease-in-out, visibility 0.25s ease-in-out, max-height 0s linear 0.25s;
					transition: opacity 0.25s ease-in-out, transform 0.25s ease-in-out, visibility 0.25s ease-in-out, max-height 0s linear 0.25s, -webkit-transform 0.25s ease-in-out;
					will-change: transform;
					.parkrise-box-triangle {
						position: absolute;bottom: calc(100% - 2px);
						margin:0 auto;width: 22px; height: 15px;right:19px; 
					}
					.parkrise-box-triangle svg{
						-webkit-filter: drop-shadow(0 -3px 2px rgba(0, 0, 0, 0.12));
						filter: drop-shadow(0 -3px 2px rgba(0, 0, 0, 0.12));
					}
					.parkrise-header-dropdown_content{
						width: 100%;height: 100%;	max-height: 100%;overflow: hidden;padding: 15px 20px;
						.parkrise-sitenav-content .parkrise-boxtitle{
							font-size: 18px;color:$colorText;text-transform: uppercase;letter-spacing: 0.5px;
							margin: 0;font-weight: 500;padding-bottom:8px;text-align:center;
						}
					}
				}	
				&.parkrise-header-action_account .parkrise-header-action_dropdown .parkrise-box-triangle{right:58px;}
				&.parkrise-header-action_search .parkrise-header-action_dropdown .parkrise-box-triangle{right:98px;}
				&.parkrise-header-action_cart{position: relative;}
        &.parkrise-header-action_info{
          .parkrise-header-action_text .parkrise-header-action__link .parkrise-box-icon{
            display: flex;align-items: center;margin-left: 10px;
          }
          .parkrise-hamburger-menu{
            width: 20px;height: 20px;display: inline-block;
            background: $colorHd;
