.parkrise-sitenav-inner{
	.parkrise-sitenav-header{
		display: flex;flex-wrap: wrap;
		justify-content: space-between;
		padding: 15px;
		border-bottom: 1px solid $colorBoder;
		&__title{font-size: 22px;font-weight: 600;margin: 0;color: $colorText;}
		&__btn{
			svg{width: 17px;height:100%;margin:0 auto;cursor: pointer;fill: $colorText;}
		}
		.parkrise-cart-shipping{
			flex: 0 0 100%;
			max-width: 100%;
			margin-top:18px;
			&__title{
				font-size: 14px;
				font-weight: 400;
				color: rgba($colorText, 0.6);
				letter-spacing: 0.5px;
				min-height: 30px;
				.price {font-weight: 600;color: #ff2c26;}
				.free-ship {text-transform: uppercase;color: $colorText;font-weight: 600;}
			}
		}
	}
	.parkrise-sitenav-content{
		padding: 15px;
		position: relative;
		overflow-y: scroll;
		height: 100%;
		-webkit-overflow-scrolling: touch;
		-ms-scroll-chaining: none;
		overscroll-behavior: none;
		&::-webkit-scrollbar {width:4px;	height: 3px;}
		&::-webkit-scrollbar-track {-webkit-border-radius:2px;border-radius: 2px;margin-left: 10px;}
		&::-webkit-scrollbar-thumb {
			-webkit-border-radius:2px;border-radius:2px;background:#e1e3e4;
			-webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3); 
		}
		&::-webkit-scrollbar-thumb:window-inactive {background:#e1e3e4; }
	}
	.parkrise-sitenav-footer{padding: 15px;margin-top:auto;border-top: 1px solid $colorBoder;}
}

.parkrise-menuList-links{margin:0;}
.parkrise-menuList-links li{position: relative;}
.parkrise-menuList-links li a {color:$colorText;position: relative;font-size: 13px;display: block;}
@media (min-width: 992px) {
  .parkrise-menuList-links li a:hover,.parkrise-menuList-links li a:focus{color:$colorHdHover;}
}
.parkrise-menuList-links > li{border-bottom: 1px dashed $colorBoder;}
.parkrise-menuList-links > li:last-child{border-bottom: none;}
.parkrise-menuList-links > li > a {padding:12px 0;font-weight: 500;font-size: 15px;}
.parkrise-menuList-links > li.parkrise-has-submenu >a{padding-right:30px}
.parkrise-menuList-links > li.parkrise-has-submenu span.parkrise-icon-plus-submenu {	width: 25px;height:25px;cursor: pointer;position: absolute;right: 0;top: 0;bottom: 0;margin: auto;border: none;}
.parkrise-icon-plus-submenu:after,.parkrise-icon-plus-submenu:before {
	background: rgba($colorText,0.6);content: '';display: block;	position: absolute;	margin-right:7px;	top: 50%;right: 0;
	-moz-transition: all .25s linear;-o-transition: all .25s linear;-webkit-transition: all .25s linear;transition: all .25s linear;
}
.parkrise-icon-plus-submenu:before{width: 9px;height: 1px;	-moz-transform: translateY(-50%);	-ms-transform: translateY(-50%);-webkit-transform: translateY(-50%);transform: translateY(-50%);}
.parkrise-icon-plus-submenu:after {width: 1px;	height:9px;	right:4px;transform-origin: center;	-moz-transform: translateY(-50%) scale(1, 1);	-ms-transform: translateY(-50%) scale(1, 1);	-webkit-transform: translateY(-50%) scale(1, 1);transform: translateY(-50%) scale(1, 1);}
li.parkrise-has-submenu.opened > a .parkrise-icon-plus-submenu:after {-moz-transform: translateY(-50%) scale(1, 0);-ms-transform: translateY(-50%) scale(1, 0);-webkit-transform: translateY(-50%) scale(1, 0); transform: translateY(-50%) scale(1, 0);}
ul.parkrise-menuList-links li ul.parkrise-submenu-links{display: none;}
ul.parkrise-submenu-links li a{ padding: 8px 0 8px 0px;}
li.parkrise-has-submenu.parkrise-level0 > ul.parkrise-submenu-links{border-top: 1px dashed $colorBoder;}
li.parkrise-has-submenu.parkrise-level0 > ul.parkrise-submenu-links li a{padding-left:12px;}
li.parkrise-has-submenu.parkrise-level1 > ul.parkrise-submenu-links li a{padding-left:25px;}
li.parkrise-has-submenu.parkrise-level2 > ul.parkrise-submenu-links li a{padding-left:35px;}

