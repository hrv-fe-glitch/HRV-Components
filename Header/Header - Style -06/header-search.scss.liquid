.parkrise-smart-search-wrapper {
	width: 100%;
	background: #fff;
}
.parkrise-smart-search-wrapper .parkrise-item-ult {
	padding: 12px 0;
	border-bottom: 1px dotted #dfe0e1;
	clear: both;
	width: 100%;
	float: left;
}
.parkrise-smart-search-wrapper .parkrise-item-ult .parkrise-thumbs {
	width: 40px;
	display: inline-block;
	text-align: right;
}
.parkrise-smart-search-wrapper .parkrise-item-ult .parkrise-title {
	width: calc(100% - 40px);
	padding-right: 5px;
	float: left;
	line-height: 20px;
	position: relative;
	margin-top: 0 !important;
}
.parkrise-smart-search-wrapper .parkrise-item-ult .parkrise-title a {
	font-size: 13px;
	text-overflow: ellipsis;
	overflow: hidden;
	white-space: pre;
	float: left;
	width: 100%;
	margin: 10px 0 5px;
}
.parkrise-smart-search-wrapper .parkrise-item-ult .parkrise-title p {
	line-height: 15px;
	font-size: 12px;
	font-weight: 500;
	float: left;
	margin: 0;
}
.parkrise-smart-search-wrapper .parkrise-item-ult .parkrise-title p del {
	font-size: 11px;
	font-weight: 400;
	margin-left: 7px;
	color: #797979;
}
.parkrise-smart-search-wrapper .parkrise-resultsMore {
	width: 100%;
	float: left;
}
.parkrise-smart-search-wrapper .parkrise-resultsMore a {
	text-align: center;
	display: block;
	font-size: 13px;
	padding: 10px 0;
}
.parkrise-smart-search-wrapper .parkrise-dataEmpty {
	text-align: center;
	padding: 20px 0;
}