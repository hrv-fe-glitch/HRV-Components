:root {
  --header-bg: {{settings.agrimarket_header_color_bkg}};
  --header-text: {{settings.agrimarket_header_color_text}};
  --header-bg-middle: {{settings.agrimarket_headerTop_color_bkg}};
  --header-text-middle: {{settings.agrimarket_headerTop_color_text}};
  --header-button-middle: {{settings.agrimarket_headerTop_color_button}};
  --header-btn-bg: {{settings.agrimarket_header_button2_bgColor}};
  --header-btn-text: {{settings.agrimarket_header_button2_textColor}};
  --header-label-bg: {{settings.agrimarket_header_label_bgColor}};
  --header-label-text: {{settings.agrimarket_header_label_textColor}};
  --submenu-text: #000;
  --submenu-bg: #fff;
}
/*
--------------------------------------------------------------------------------
SIDEBAR MAIN
--------------------------------------------------------------------------------
*/
.agrimarket-sidebar-main {
	.agrimarket-sitenav-wrapper {
		position: fixed;
		top: 0;
		bottom: 0;
		z-index: 1010;
		background: transparent;
		&.agrimarket-sitenav-right {
			right: 0;
			.agrimarket-sitenav-inner {
				right: 0;
				-webkit-transform: translateX(120%);
				transform: translateX(120%);
				-webkit-transition: transform 0.35s ease
					, right 0.25s ease
					, visibility 0s;
				transition: transform 0.35s ease
					, right 0.25s ease
					, visibility 0s;
			}
		}
		&.agrimarket-sitenav-left {
			left: 0;
			.agrimarket-sitenav-inner {
				left: 0;
				-webkit-transform: translateX(-100%);
				transform: translateX(-100%);
				-webkit-transition: transform 0.35s ease
					, left 0.25s ease
					, visibility 0s;
				transition: transform 0.35s ease
					, left 0.25s ease
					, visibility 0s;
			}
		}
		.agrimarket-sitenav-inner {
			margin: 0 auto;
			max-width: 480px;
			position: absolute;
			top: 0;
			bottom: 0;
			background: #ffffff;
			background-clip: padding-box;
			display: flex;
			flex-direction: column;
			&:after {
				content: "";
				position: absolute;
				width: 100%;
				height: 100%;
				background: #fff;
				z-index: 1;
				opacity: 1;
				visibility: visible;
			}
		}
	}
	&.agrimarket-is-show-right {
		.agrimarket-sitenav-wrapper.agrimarket-show {
			left: 0 !important;
			-webkit-transition-delay: 0s;
			transition-delay: 0s;
		}
		.agrimarket-sitenav-wrapper.agrimarket-show .agrimarket-sitenav-inner {
			right: 0;
			width: 85%;
			-webkit-transform: translateX(0);
			transform: translateX(0);
			-webkit-transition-delay: 0.1s;
			transition-delay: 0.1s;
			-webkit-transition-duration: 0.3s;
			transition-duration: 0.3s;
			&:after {
				visibility: hidden;
				opacity: 0;
			}
		}
		.agrimarket-sitenav-wrapper.agrimarket-show .agrimarket-sidebar-overlay {
			opacity: 1;
			visibility: visible;
		}
	}
	&.agrimarket-is-show-left {
		.agrimarket-sitenav-wrapper.agrimarket-show {
			right: 0 !important;
			-webkit-transition-delay: 0s;
			transition-delay: 0s;
		}
		.agrimarket-sitenav-wrapper.agrimarket-show .agrimarket-sitenav-inner {
			left: 0;
			width: 85%;
			-webkit-transform: translateX(0);
			transform: translateX(0);
			-webkit-transition-delay: 0.1s;
			transition-delay: 0.1s;
			-webkit-transition-duration: 0.3s;
			transition-duration: 0.3s;
			&:after {
				visibility: hidden;
				opacity: 1;
			}
		}
		.agrimarket-sitenav-wrapper.agrimarket-show .agrimarket-sidebar-overlay {
			opacity: 1;
			visibility: visible;
		}
	}
	.agrimarket-sidebar-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: 100%;
		z-index: -1;
		background-color: rgba(0, 0, 0, 0.5);
		opacity: 0;
		visibility: hidden;
		transition: all 0.4s cubic-bezier(0.645, 0.045, 0.355, 1);
	}
}
.agrimarket-sitenav-inner {
	.agrimarket-sitenav-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		padding: 15px;
		border-bottom: 1px solid var(--shop-color-border);
		&__title {
			font-size: 22px;
			font-weight: 600;
			margin: 0;
		}
		&__btn {
			svg {
				width: 17px;
				height: 100%;
				margin: 0 auto;
				cursor: pointer;
			}
		}
		.agrimarket-cart-shipping {
			flex: 0 0 100%;
			max-width: 100%;
			margin-top: 18px;
			&__title {
				font-size: 14px;
				font-weight: 400;
				color: #666666;
				letter-spacing: 0.5px;
				min-height: 30px;
				.price {
					font-weight: 600;
					color: #ff2c26;
				}
				.free-ship {
					text-transform: uppercase;
					color: #333333;
					font-weight: 600;
				}
			}
		}
	}
	.agrimarket-sitenav-content {
		padding: 15px;
		position: relative;
		overflow-y: scroll;
		height: 100%;
		-webkit-overflow-scrolling: touch;
		-ms-scroll-chaining: none;
		overscroll-behavior: none;
		&::-webkit-scrollbar {
			width: 4px;
			height: 3px;
		}
		&::-webkit-scrollbar-track {
			-webkit-border-radius: 2px;
			border-radius: 2px;
			margin-left: 10px;
		}
		&::-webkit-scrollbar-thumb {
			-webkit-border-radius: 2px;
			border-radius: 2px;
			background: #e1e3e4;
			-webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
		}
		&::-webkit-scrollbar-thumb:window-inactive {
			background: #e1e3e4;
		}
		.agrimarket-more-notify {
			padding: 8px 0;
			border-top: 1px solid var(--shop-color-border);
		}
		.agrimarket-more-notify a {
			color: #0d6efd;
		}
	}
	.agrimarket-sitenav-footer {
		padding: 15px;
		margin-top: auto;
		border-top: 1px solid var(--shop-color-border);
	}
}
.agrimarket-sitenav-content {
	.agrimarket-btnclose {
		display: none;
		width: 30px;
		height: 30px;
		position: absolute;
		right: 10px;
		top: 13px;
		z-index: 5;
		border: 0;
		background: transparent;
		text-align: center;
		outline: none;
		svg {
			width: 16px;
			height: 30px;
		}
	}
	&__title {
		position: relative;
		padding: 0 0 10px;
		border-bottom: 1px solid var(--shop-color-border);
		text-align: center;
		.agrimarket-btn-close {
			display: none;
			width: 32px;
			height: 30px;
			position: absolute;
			right: 0;
			top: -6px;
			border: 0;
			background: transparent;
			text-align: center;
			outline: none;
			svg {
				width: 18px;
				height: 30px;
			}
		}
		.agrimarket-txt-title {
			font-size: 18px;
			color: var(--shop-color-title);
			text-transform: uppercase;
			letter-spacing: 0.5px;
			margin: 0;
			font-weight: 500;
		}

	}
	&__block {
		padding-top: 20px;
	}
	@media(min-width: 992px) {
		.agrimarket-sitenav-boxscroll {
			overflow-y: scroll;
			max-height: 55vh;
			-webkit-overflow-scrolling: touch;
			-ms-scroll-chaining: none;
			overscroll-behavior: none;
			margin-right: -20px;
			padding-right: 20px;
		}
		.agrimarket-sitenav-boxscroll::-webkit-scrollbar {
			width: 4px;
			height: 3px;
		}
		.agrimarket-sitenav-boxscroll::-webkit-scrollbar-track {
			-webkit-border-radius: 2px;
			border-radius: 2px;
		}
		.agrimarket-sitenav-boxscroll::-webkit-scrollbar-thumb {
			-webkit-border-radius: 2px;
			border-radius: 2px;
			background: #e1e3e4;
			-webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
		}
		.agrimarket-sitenav-boxscroll::-webkit-scrollbar-thumb:window-inactive {
			background: #e1e3e4;
		}
	}
	@media(max-width: 767px) {
		.btnclose {
			display: block;
		}
		&__title {
			text-align: left;
			padding-right: 40px;
			.btn-close {
				display: block;
			}
			.agrimarket-txt-title {
				font-size: 15px;
			}
		}
	}
}
.agrimarket-sitenav-locate {
	.agrimarket-sitenav-content__block {
		padding-top: 15px;
		.agrimarket-boxaddress {
			border: 1px solid var(--shop-color-border);
			border-radius: 5px;
			padding: 6px 15px;
			font-size: 13px;
			background: var(--shop-color-border);
			color: var(--shop-color-text);
			span {
				display: block;
				font-weight: 500;
			}
		}
		.agrimarket-boxprovince {
			padding: 10px 0;
			.textprov {
				color: #000;
				font-weight: 500;
				margin-bottom: 10px;
			}
			.agrimarket-listprov {
				li {
					position: relative;
					cursor: pointer;
					padding: 10px 0 10px 35px;
					transition: background 0.4s ease;
					font-size: 13px;
					color: var(--shop-color-text);
					border-top: 1px dotted var(--shop-color-border);
					.agrimarket-address-name {
						display: block;
						font-weight: 600;
					}
					.agrimarket-icmap {
						width: 18px;
						height: 18px;
						position: absolute;
						top: 15px;
						left: 8px;
					}
				}
				li:hover {
					background: var(--shop-color-border);
				}
			}
		}
		.agrimarket-boxfilter {
			margin-bottom: 3px;
			.agrimarket-filter-select {
				margin-right: -5px;
				margin-left: -5px;
				display: -ms-flexbox;
				display: flex;
			}
			.agrimarket-filter-select .agrimarket-select-item {
				-ms-flex-preferred-size: 0;
				flex-basis: 0;
				-ms-flex-positive: 1;
				flex-grow: 1;
				min-width: 0;
				max-width: 50%;
				padding-left: 5px;
				padding-right: 5px;
				margin-bottom: 10px;
			}
			.agrimarket-filter-select .agrimarket-select-item .agrimarket-field-select {
				position: relative;
			}
			.agrimarket-filter-select .agrimarket-select-item .agrimarket-field-select:after {
				content: '';
				position: absolute;
				top: calc(50% - 5px);
				right: 12px;
				border: solid #666666;
				border-width: 0 1px 1px 0;
				display: inline-block;
				padding: 3px;
				transform: rotate(45deg);
				-webkit-transform: rotate(45deg);
			}
			.agrimarket-filter-select .agrimarket-select-item label {
				display: block;
				font-weight: 500;
				font-size: 13px;
				margin: 0 0 5px;
			}
			.agrimarket-filter-select .agrimarket-select-item select {
				padding: 0 25px 0 8px;
				cursor: pointer;
				outline: none;
				text-overflow: ellipsis;
				border-radius: 4px;
				height: 34px;
				line-height: 32px;
				background: #ffffff;
				border: 1px solid var(--shop-color-border);
				font-size: 13px;
				width: 100%;
				color: #000;
				font-weight: 500;
				-webkit-user-select: none;
				-moz-user-select: none;
				-ms-user-select: none;
				user-select: none;
				-webkit-appearance: none;
				-moz-appearance: none;
				-ms-appearance: none;
				-o-appearance: none;
				appearance: none;
			}
			.agrimarket-filter-select .agrimarket-select-item select:-ms-expand {
				display: none;
			}
			.agrimarket-filter-select .agrimarket-select-item select:invalid {
				color: #677279;
			}
			.agrimarket-filter-select .agrimarket-select-item select [disabled] {
				color: #ededed;
				font-weight: 300;
			}
			.agrimarket-filter-select .agrimarket-select-item select option {
				color: #000;
				font-weight: 500;
				line-height: 18px;
			}
			.agrimarket-filter-select .agrimarket-select-item select option[value="null"] {
				color: #677279;
			}
		}
	}
}
.agrimarket-sitenav-search {
	margin-bottom: 20px;

	form.agrimarket-searchform {
		position: relative;
		padding: 0;
	}
	form.agrimarket-searchform input.agrimarket-input-search {
		height: 44px;
		line-height: 28px;
		padding: 8px 50px 8px 20px;
		width: 100%;
		background: #f6f6f6;
		border: 1px solid #ebebeb;
		font-size: 15px;
		font-weight: 500;
		margin: 0;
		display: inline-block;
		border-radius: 0;
		-webkit-appearance: none;
		-moz-appearance: none;
		-o-appearance: none;
		appearance: none;
	}
	form.agrimarket-searchform .agrimarket-btn-search {
		width: 50px;
		height: 44px;
		line-height: 40px;
		position: absolute;
		padding: 0;
		top: 0;
		right: 0;
		background: transparent;
		transition: opacity 150ms linear;
	}
	form.agrimarket-searchform .agrimarket-btn-search svg {
		width: 18px;
		height: 44px;
		opacity: 0.4;
	}
	form.agrimarket-searchform input.agrimarket-input-search:focus {
		background: #f2f5fa;
		outline: none;
		border-color: var(--shop-color-main);
	}
	form.agrimarket-searchform.agrimarket-expanded .agrimarket-btn-search svg {
		opacity: 1;
	}
	.agrimarket-smart-search-wrapper .agrimarket-dataEmpty {
		padding-bottom: 0;
	}
}

.agrimarket-sitenav-account {
	.agrimarket-site_account_panel_list {
		position: relative;
		height: 100%;
		overflow: hidden;
		transition: height 0.2s ease-in-out;
		.agrimarket-site_account_header {
			margin: 0 0 20px;
			padding-bottom: 8px;
			text-align: center;
			border-bottom: 1px solid var(--shop-color-border);
			.agrimarket-site_account_title {
				font-size: 18px;
				color: var(--shop-color-title);
				text-transform: uppercase;
				letter-spacing: 0.5px;
				font-weight: 500;
				margin: 0;
				&.agrimarket-size-small {
					font-size: 15px;
				}
			}
			.agrimarket-site_account_legend {
				margin: 5px 0 0;
				font-size: 14px;
			}
		}
		.agrimarket-site_account_panel {
			width: 100%;
			visibility: hidden;
			transition: visibility 400ms cubic-bezier(0.23, 1, 0.32, 1)
				, -webkit-transform 400ms cubic-bezier(0.23, 1, 0.32, 1);
			transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1)
				, visibility 400ms cubic-bezier(0.23, 1, 0.32, 1);
			transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1)
				, visibility 400ms cubic-bezier(0.23, 1, 0.32, 1)
				, -webkit-transform 400ms cubic-bezier(0.23, 1, 0.32, 1);

			&.agrimarket-site_account_default {
				-webkit-transform: translateX(-100%);
				transform: translateX(-100%);
			}
			&.agrimarket-site_account_sliding {
				position: absolute;
				top: 0;
				left: 0;
				-webkit-transform: translateX(100%);
				transform: translateX(100%);
			}
			&.agrimarket-is-selected {
				-webkit-transform: translateX(0);
				transform: translateX(0);
			}
			.agrimarket-site_account_inner {
				form .agrimarket-form__input-wrapper {
					position: relative;
					width: 100%;
					margin-bottom: 12px;
				}
				form .agrimarket-form__input-wrapper .agrimarket-form__field {
					display: block;
					padding: 14px 10px 3px;
					border-radius: 2px;
					border: 1px solid #d4d6d8;
					width: 100%;
					line-height: normal;
					height: 42px;
					color: #1e2d7d;
					-webkit-appearance: none;
					resize: none;
					font-size: 12px;
					outline: none;
					box-shadow: 0 1px rgba(212, 214, 216, 0.25) inset;
					transition: border-color 0.2s ease-in-out
						, box-shadow 0.2s ease-in-out
						, color 0.2s ease-in-out;
				}
				form .agrimarket-form__input-wrapper .agrimarket-form__floating-label {
					position: absolute;
					left: 10px;
					top: 0;
					line-height: 42px;
					font-size: 12px;
					margin-bottom: 0;
					color: #677279;
					-webkit-transform: scale(1);
					transform: scale(1);
					-webkit-transform-origin: left top;
					transform-origin: left top;
					transition: -webkit-transform 0.2s ease-in-out;
					transition: transform 0.2s ease-in-out;
					transition: transform 0.2s ease-in-out
						, -webkit-transform 0.2s ease-in-out;
					pointer-events: none;
				}
				form .agrimarket-form__input-wrapper .agrimarket-form__field:focus + .agrimarket-form__floating-label,
				form .agrimarket-form__input-wrapper .agrimarket-form__field.is-filled + .agrimarket-form__floating-label {
					-webkit-transform: translateY(-5px) scale(0.8);
					transform: translateY(-5px) scale(0.8);
				}
				form .agrimarket-form__submit {
					width: 100%;
					outline: none;
					padding: 0 28px;
					height: 42px;
					line-height: 42px;
				}
				.agrimarket-site_account_secondary-action {
					margin-top: 16px;
					font-size: 12px;
				}
				.agrimarket-site_account_secondary-action > p {
					margin-bottom: 4px;
				}
				.agrimarket-site_account_secondary-action > p .link {
					color: var(--shop-color-main);
					transition: color 0.2s ease-in-out;
					background: transparent;
					border: none;
					border-radius: 0;
					padding: 0;
					outline: none;
				}
			}
		}
		.agrimarket-site_account_info {
			text-align: left;
			font-size: 14px;
			.agrimarket-site_account_inner {
				ul {
					margin: 0;
				}
				ul li {
					position: relative;
					margin-bottom: 5px;
					&.user-name {
						margin-top: -5px;
						margin-bottom: 8px
					}
					&:not(.user-name) {
						padding-left: 10px;
						&:before {
							content: "";
							height: 4px;
							width: 4px;
							border-radius: 50%;
							position: absolute;
							left: 0;
							top: 10px;
							background: var(--shop-color-text);
						}
					}
				}
				ul li span {
					font-size: 15px;
					color: #282c2d;
					font-weight: 500;
				}
				ul li a {
					color: var(--shop-color-text);
					padding: 0 4px;
					margin-bottom: 10px;
				}
				ul li a:hover {
					color: var(--shop-color-hover);
				}
			}
		}
	}
}
.agrimarket-sitenav-overlay {
	background: rgba(225, 225, 225, 0.05);
	position: fixed;
	left: 0;
	top: 0;
	z-index: 90;
	width: 100vw;
	height: 100vh;
	opacity: 0;
	visibility: hidden;
	transition: all 200ms linear;
}
.agrimarket-sitenav-menu {
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__section-title {
		font-size: 15px;
		color: var(--shop-color-title);
		margin-bottom: 15px;
		text-transform: uppercase;
		font-weight: 500;
		font-style: normal;
	}
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__help-wrapper + .agrimarket-mobile-menu__help-wrapper {
		margin-top: 15px;
	}
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__help-wrapper {
		color: #677279;
		display: flex;
		display: -ms-flex;
		align-items: center;
	}
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__help-wrapper .icon--bi-phone {
		margin-right: 16px;
		width: 24px;
		height: 24px;
	}
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__help-wrapper .icon--bi-email {
		margin-right: 18px;
		width: 22px;
		height: 22px;
	}
	.agrimarket-mobile-menu__section .agrimarket-mobile-menu__help-wrapper a {
		border-bottom: 0 !important;
		text-transform: none !important;
	}
	.agrimarket-menuList-links {
		li.agrimarket-has-submenu.level0 > ul.agrimarket-submenu-links {
			border: 0;
		}
		& > li {
			border: 0;
		}
		& > li > a {
			font-weight: 600;
		}
		& > li.agrimarket-has-submenu .agrimarket-icon-plus-submenu:hover {
			border: none;
		}
		.agrimarket-has-submenu.level0 > ul.agrimarket-submenu-links li a {
			font-weight: 500;
		}
	}
  .agrimarket-menuList-links {
