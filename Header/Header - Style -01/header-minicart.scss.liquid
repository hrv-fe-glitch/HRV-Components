:root {
  --mnc-bg: {{settings.agrimarket_mnc_cart_bkg}};
  --mnc-text: {{settings.agrimarket_mnc_cart_text}};
  --mnc-button: {{settings.agrimarket_mnc_cart_button}};
  --mnc-border: {{settings.agrimarket_mnc_cart_border}};

  --cp-md-border: {{settings.agrimarket_header_coupon_border}};
  --header-coupon-text: {{settings.agrimarket_header_coupon_text}};
  --header-coupon-btn-bg: {{settings.agrimarket_header_coupon_btn_bg}};
  --header-coupon-btn-color: {{settings.agrimarket_header_coupon_btn_color}};
}
.agrimarket-sidebar-main .agrimarket-sitenav-wrapper.agrimarket-sitenav-cart .agrimarket-sitenav-inner {
  background: var(--mnc-bg);
  .agrimarket-sitenav-footer {
    border-top: 1px solid var(--mnc-border);
  }
  .agrimarket-sitenav-header__btn svg {
    fill: currentcolor;
  }
}
.agrimarket-sitenav-cart {
  color: var(--mnc-text);
	.agrimarket-cart-view-scroll {
		.agrimarket-mini-cart__item {
			position: relative;
			border-bottom: 1px dotted var(--mnc-border);
			display: -webkit-box;
			display: -ms-flexbox;
			display: flex;
			padding: 12px 0;
			&:last-child {
				border-bottom: 0;
			}
			td {
				padding-top: 12px;
				padding-bottom: 12px;
				position: relative;
				vertical-align: middle
			}
			.agrimarket-mini-cart__left {
				width: 90px;
				padding-right: 15px;
				max-width: none;
				text-align: center;
				img {
					display: block;
					border: 1px solid var(--mnc-border);
				}
				.agrimarket-mnc-gift {
					position: absolute;
					top: 5px;
					left: 0;
					display: block;
					padding: 4px;
					background: #ffffff;
					border: 1px solid var(--mnc-border);
					width: 24px;
					height: 24px;
					text-align: center;
					line-height: 24px;
					border-radius: 50%;
					img {
						border: 0;
						margin: auto;
					}
				}
			}
			.agrimarket-mini-cart__right {
				padding-left: 5px;
				flex: 0 0 calc(100% - 90px);
				max-width: calc(100% - 90px);
				.agrimarket-mini-cart__title {
					.agrimarket-mnc-title {
						display: block;
						font-size: 14px;
						font-weight: 600;
						padding-right: 28px;
						text-transform: uppercase;
						color: var(--mnc-text);
					}
					.agrimarket-mnc-variant {
						display: block;
						font-size: 13px;
						margin: 0 0 7px;
					}
				}
				.agrimarket-mini-cart__quantity {
					.agrimarket-qty-value {
						float: left;
						width: 28px;
						height: 28px;
						background: #fff;
						text-align: center;
						font-size: 13px;
						line-height: 1;
						color: #252a2b;
						border: 0;
						border-top: 1px solid var(--mnc-border);
						border-bottom: 1px solid var(--mnc-border);
						padding: 0;
						&:focus {
							outline: none;
						}
					}
					.agrimarket-qty-btn {
						float: left;
						font-weight: 500;
						font-size: 18px;
						padding: 0;
						height: 28px;
						width: 28px;
						text-align: center;
						background: #f9f9f9;
						color: var(--mnc-text);
						border: 1px solid #f9f9f9;
						outline: none;
						-webkit-appearance: none;
						-moz-appearance: none;
						-o-appearance: none;
						appearance: none;
						display: flex;
						align-items: center;
						justify-content: center;
						svg {
							display: block;
							width: 10px;
							height: 100%;
							margin: 0 auto;
						}
					}
				}
				.agrimarket-mini-cart__price {
					display: flex;
					display: -ms-flex;
					justify-content: flex-end;
					-ms-justify-content: flex-end;
					flex-direction: column;
					-ms-flex-direction: column;
				}
				.agrimarket-mini-cart__price .agrimarket-mnc-price {
					display: block;
					text-align: right;
					float: right;
					line-height: 26px;
					font-weight: 600;
					color: var(--mnc-text);
				}
				.agrimarket-mini-cart__price .agrimarket-mnc-ori-price {
					text-align: right;
					float: right;
				}
				.agrimarket-mini-cart__remove {
					position: absolute;
					right: 0;
					top: 10px;
					width: 20px;
					height: 20px;
					line-height: 20px;
					text-align: center;
				}
				.agrimarket-mini-cart__remove a {
					width: 20px;
					height: 20px;
					line-height: 20px;
					display: block;
					color: var(--mnc-text);
				}
				.agrimarket-mini-cart__remove a svg {
					width: 12px;fill: currentcolor;
				}
			}
		}
		.agrimarket-mini-cart__empty {
			.agrimarket-svgico-mini-cart {
				padding-top: 20px;
				padding-bottom: 20px;
				position: relative;
				text-align: center;
			}
			.agrimarket-svgico-mini-cart svg {
				stroke: var(--mnc-text);
				width: 50px;
				height: 50px;
				margin: auto;
			}
		}
	}
	.agrimarket-cart-view-line {
		clear: both;
		width: 100%;
		border-top: 1px solid var(--mnc-border);
		margin: 0 0 5px;
	}
	.agrimarket-cart-view-total {
		.agrimarket-total-price {
			display: -webkit-box;
			display: -ms-flexbox;
			display: flex;
			align-items: center;
			justify-content: space-between;
		}
		.agrimarket-mnc-total {
			font-size: 16px;
			font-weight: 500;
			color: var(--mnc-text);
		}
		#agrimarket-total-view-cart {
			font-weight: 600;
			font-size: 18px;
			color: var(--mnc-button);
			text-align: right;
		}
		.agrimarket-linktocheckout {
			margin: 5px 0;
			padding: 10px;
			font-size: 12px;
			text-transform: uppercase;
			width: 100%;
			background-color: var(--mnc-button);
			border-color: var(--mnc-button);
			color: #ffffff;
			display: block;
		}
		.agrimarket-linktocheckout.disabled {
			pointer-events: none;
			opacity: 0.7;
			background: var(--mnc-button);
			border-color: var(--mnc-button);
		}
		.agrimarket-linktocheckout:before {
			background-color: var(--mnc-button);
		}
		.agrimarket-linktocart {
			display: block;
			font-size: 14px;
			text-decoration: underline;
			color: var(--mnc-button);
		}
		.agrimarket-linkcoupon {
			border: 0;
			font-size: 14px;
			text-decoration: underline;
			color: var(--mnc-button);
			cursor: pointer;
		}
		.agrimarket-action-link {
			display: flex;
			justify-content: space-between;
		}
		.agrimarket-action-link-empty {
			display: none;
		}
		.agrimarket-summary-alert {
			display: none;
			background-color: #fee3e8;
			border: 1px solid #fdd0d8;
			color: #d20909;
			font-size: 13px;
			padding: 10px 15px;
			margin: 10px 0;
			text-align: left;
		}
	}
	.agrimarket-cart-shipping {
		.agrimarket-shipping-title {
			font-size: 16px;
			font-weight: 400;
			color: #666666;
			letter-spacing: 0.5px;
			min-height: 30px;
		}
		.agrimarket-price {
			font-weight: 600;
			color: #ff2c26;
		}
		.agrimarket-free-ship {
			text-transform: uppercase;
			color: #333333;
			font-weight: 600;
		}
		&__bar {

			height: 8px;
			width: 100%;
			background-color: #e9e9e9;
			border-radius: 5px;
			margin: 15px 0 10px;
			position: relative;
			.agrimarket-shipping-bar {
				padding-left: 20px;
				padding-right: 5px;
			}
			span {
				background-color: #ffbc11;
				width: 0;
				border-radius: 5px;
				transition: width 0.4s ease-in-out;
				display: block;
				height: 100%;
				position: relative;
				.agrimarket-icon {
					width: 30px;
					height: 30px;
					display: inline-flex;
					align-items: center;
					justify-content: center;
					border-radius: 50%;
					position: absolute;
					top: 3px;
					right: 14px;
					transform: translate(50%, -50%);
					font-weight: 700;
					content: "";
					font-size: 12px;
					color: #ffbc11;
					border: 1px solid #ffbc11;
					background: currentColor;
					svg {
						fill: #fff;
					}
				}
			}
		}
		&.agrimarket-cart-shipping-free {
			.agrimarket-cart-shipping__bar .agrimarket-shipping-bar {
				background-color: #3d9851;
			}
			.agrimarket-cart-shipping__bar .agrimarket-shipping-bar .agrimarket-icon {
				background-color: #3d9851;
				border-color: #3d9851;
				color: #3d9851;
			}
		}
	}
	&.agrimarket-cart-empty {
		.agrimarket-cart-shipping {
			display: none;
		}
		.agrimarket-sitenav-footer {
			display: none;
		}
		.agrimarket-action-link-empty {
			display: flex;
			justify-content: space-around;
			margin-top: 10px;
		}
		.agrimarket-linkreturn,
		.agrimarket-linkcoupon {
			background: #fff;
			border: 0;
			font-size: 14px;
			text-decoration: underline;
			color: #1a73e8;
			cursor: pointer;
		}
	}
	@media(min-width: 992px) {
		.agrimarket-mini-cart__empty .agrimarket-svgico-mini-cart {
			padding: 10px 0 5px;
		}
		.agrimarket-mini-cart__empty .agrimarket-svgico-mini-cart p {
			font-size: 18px;
		}
		.agrimarket-cart-view-scroll::-webkit-scrollbar {
			width: 4px;
			height: 3px;
		}
		.agrimarket-cart-view-scroll::-webkit-scrollbar-track {
			-webkit-border-radius: 2px;
			border-radius: 2px;
		}
		.agrimarket-cart-view-scroll::-webkit-scrollbar-thumb {
			-webkit-border-radius: 2px;
			border-radius: 2px;
			background: #e1e3e4;
			-webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
		}
		.agrimarket-cart-view .agrimarket-cart-view-scroll::-webkit-scrollbar-thumb:window-inactive {
			background: #e1e3e4;
		}
	}
	@media(max-width: 991px) {
		.agrimarket-mini-cart__empty .agrimarket-svgico-mini-cart {
			padding: 0 0 5px;
		}
		.agrimarket-cart-view-scroll {
			.agrimarket-mini-cart__item {
				.mini-cart__right .agrimarket-mini-cart__title {
					margin-bottom: 0;
				}
			}
		}
		.agrimarket-cart-view-coupon {
			display: none;
		}
		.agrimarket-sitenav-header .agrimarket-cart-shipping {
			margin-top: 15px;
		}
		&.agrimarket-cart-empty .agrimarket-action-link-empty {
			flex-direction: column;
		}
		&.agrimarket-cart-empty .agrimarket-action-link-empty a {
			margin-bottom: 8px;
		}
	}
	@media(max-width: 575px) {
		.agrimarket-cart-shipping .agrimarket-free-ship {
			display: block;
		}
		.agrimarket-cart-shipping.agrimarket-cart-shipping-free .agrimarket-free-ship {
			display: inline-block;
		}
	}
	@media(max-width: 360px) {
		.agrimarket-cart-view-scroll .agrimarket-mini-cart__item .agrimarket-mini-cart__right .agrimarket-mini-cart__price {
			display: block;
		}
		.agrimarket-cart-view-scroll .agrimarket-mini-cart__item .agrimarket-mini-cart__right .agrimarket-mini-cart__price .agrimarket-mnc-price {
			width: 100%;
			text-align: left;
			margin-top: 5px;
		}
	}
}

.agrimarket-coupon-initial {
	.agrimarket-listCoupon {
		background: #fff;
		display: flex; display: -ms-flex; flex-wrap: wrap;-ms-flex-wrap: wrap;
		margin-left: -7px;margin-right: -7px;
	}
	.agrimarket-title-coupon h2 {
		font-size: 16px;
		margin: 0 0 8px;
	}
	.agrimarket-coupon-item {
		padding-left: 7px;padding-right: 7px;
		&__inner {
			background: var(--header-coupon-bg);
			display: flex;display: -ms-flex;
			border-radius: 15px;
			height: 100%;
			border: 1px solid rgba(0, 0, 0, 0.08);
		}
		&__left {
			flex: 0 0 30%;-ms-flex: 0 0 30%;
			max-width: 30%;
			position: relative;
			border-right: 1px dashed var(--cp-md-border);
			padding: 8px;
			&:after, &:before {
				content: "";
				width: 20px;height: 10px;
				right: -10px;
				position: absolute;
				background: #fff;
				z-index: 1;
				border: 1px solid rgba(0, 0, 0, 0.08);
			}
			&:after {top: -1px;border-top: 0;border-bottom-left-radius: 10px;border-bottom-right-radius: 10px;}
			&:before {bottom: -1px;border-bottom: 0;border-top-left-radius: 10px;border-top-right-radius: 10px;}
			.agrimarket-cp-img {
				background: var(--header-coupon-light);
				border-radius: 10px;
			}
		}
		&__right {
			flex: 0 0 70%;
			max-width: 70%;
			position: relative;
			display: flex;display: -ms-flex;
			flex-direction: column;-ms-flex-direction: column;
			justify-content: space-between;-ms-justify-content: space-between;
			padding: 10px;
			color: var(--header-coupon-text);
			.agrimarket-cp-icon {
				background: transparent;
				border: 0;
				outline: none;
				cursor: pointer;
				position: absolute;
				top: 5px;
				right: 5px;
				padding: 5px;
			}
			.agrimarket-cp-top {
				padding-bottom: 12px;padding-right: 24px;
				h3 {
					margin: 0 0 2px;
					font-size: 14px;
					font-weight: 700;
					color: var(--header-coupon-text);
				}
				p {font-size: 12px;font-weight: 500;margin: 0;}
			} 
			.agrimarket-cp-bottom {
				display: flex;display: -ms-flex;
				justify-content: space-between;-ms-justify-content: space-between;
				.agrimarket-cp-bottom-btn {display: flex;display: -ms-flex;}
				p {font-size: 10px;margin: 0;}
				p strong {letter-spacing: 0.4px;font-size: 11px;}
			}
			.agrimarket-cp-btn {
				padding: 3px 6px;
				font-size: 10px;
				min-width: 92px;
				letter-spacing: 0.5px;
				border-radius: 20px;
				margin-top: auto;
        border: none;
        outline: none;
        background: var(--header-coupon-btn-bg);
        color: var(--header-coupon-btn-color);
			}
		}
	}
	.list-coupon-slide {padding-bottom: 15px;}
	.swiper-pagination {bottom: 0;}
	&.agrimarket-coupon-second {
		.agrimarket-coupon-item__inner {
			position: relative;
			border:0;border-radius: 0;
			border-top: 1px solid var(--header-coupon-border);
			border-bottom: 1px solid var(--header-coupon-border);
			&:before, &:after {
				content: "";
				position: absolute;
				top: 0;
				bottom: 0;
				width: 10px;
				height: 100%;
			}
			&:before {
				left: 0;
				background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, #fff 0, #fff 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 0px/1px 100% no-repeat, radial-gradient(circle at 0px 8px, #fff, #fff 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
			}
			&:after {
				right: 0;
				background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, #fff 0, #fff 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 9px/1px 100% no-repeat, radial-gradient(circle at 8px 8px, #fff, #fff 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
			}
		}
		.agrimarket-coupon-item__left {display: none;}
		.agrimarket-coupon-item__right {
			-ms-flex: 0 0 100%;flex: 0 0 100%;
			max-width: 100%;
			padding: 10px 15px;
			.agrimarket-cp-top {padding-bottom: 20px;}
		}
	}
	&.bgWhite {
		.agrimarket-coupon-item__inner:before {
			background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, transparent 0, transparent 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 0px/1px 100% no-repeat, radial-gradient(circle at 0px 8px, transparent, transparent 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
		}
		.agrimarket-coupon-item__inner:after {
			background: repeating-linear-gradient(var(--header-coupon-border), var(--header-coupon-border) 4px, transparent 0, transparent 12px, var(--header-coupon-border) 0, var(--header-coupon-border) 16px) 9px/1px 100% no-repeat, radial-gradient(circle at 8px 8px, transparent, transparent 4px, var(--header-coupon-border) 0, var(--header-coupon-border) 5px, var(--header-coupon-bg) 0) 1px 0/100% 16px repeat-y;
		}
		.agrimarket-coupon-item__left:after, .agrimarket-coupon-item__left:before {
			background: #fff;
		}
	}
	@media(max-width: 1199px) and (min-width: 768px){
		.agrimarket-coupon-item {margin-bottom: 14px;}
	}
	@media(max-width: 767px){
		.agrimarket-listCoupon {
			flex-wrap: nowrap;-ms-flex-wrap: nowrap;
			margin-left: -15px; margin-right: -15px;padding-left: 15px;
			overflow-x: scroll;-webkit-overflow-scrolling: touch;
			transition: transform 0.25s ease 0s;
			&::-webkit-scrollbar {display: none;}
			.agrimarket-coupon-item {
				padding-left: 0; padding-right: 15px; margin-bottom: 0;float: none;
				display: inline-block;flex: 0 0 90%;-ms-flex: 0 0 94%;max-width: 90%;
			}
		}
	}
}
/*--------------------------------------------------------------------------------
MODAL COUPON
--------------------------------------------------------------------------------*/
.agrimarket-modal-coupon {
  --swiper-pagination-color: var(--header-coupon-btn-bg);
  --swiper-pagination-bullet-inactive-color: var(--header-coupon-btn-bg);
  .swiper-pagination {
    position: static;
    margin-top: 5px;
  }
	.modal-dialog {max-width: 390px;}
	.modal-header {
		p {padding-right: 30px;margin: 0;font-size: 20px;font-weight: 700;line-height: initial;}
		.agrimarket-btn-close-coupon {
			position: absolute;
			top: 8px;
			right: 8px;
			margin: 0;
			opacity: 1;
			display: block;
			outline: none;
			width: 30px;
			height: 30px;
			line-height: 30px;
			border-radius: 50%;
			text-align: center;
			background: #e5e5e5;
			border: 1px solid #e5e5e5;
			padding: 0;
			margin: 0;
			svg {
				display: block;
				margin: auto;
				height: 100%;
				width: 22px;
				opacity: 0.55;
				-webkit-transition: -webkit-transform .25s, opacity .25s;
				-moz-transition: -moz-transform .25s, opacity .25s;
				transition: transform .25s, opacity .25s;
			}
			&:hover svg {
				opacity: 1;
				-webkit-transform: scale(1.12);
				-moz-transform: scale(1.12);
				transform: scale(1.12);
			}
		}
	}
	.modal-content {
		.agrimarket-title-coupon {display: none;}
		.agrimarket-coupon-item {padding: 0;}
		.agrimarket-cp-icon {display: none;}
	}
	@media(max-width: 991px){
		.agrimarket-coupon-initial .agrimarket-listCoupon {display: block;margin: 0;padding: 0;}
		.agrimarket-coupon-initial .agrimarket-listCoupon .agrimarket-coupon-item {padding: 0;flex: 0 0 100%;max-width: 100%;}
	}
}


/* NOTIFICATION PRODUCT */
.jGrowl.top-right {right: 0;top: 16%;}
.jGrowl .jGrowl-notification {
	position: relative; background: #ffffff;border:0;opacity:1;width:270px;padding-left: 20px;
	-webkit-box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.3);box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.3);
}
.jGrowl .jGrowl-notification:before{
