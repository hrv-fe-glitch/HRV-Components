RST.Footer = RST.Footer || {};
RST.Footer.newsletter = {
  init: function(){
    var that = this;
    that.submit_newsletter_form(); 
  },  
  submit_newsletter_form: () => {
    if( $('.rst_newsletter-block .contact-form').length > 0 ) {
      $('.rst_newsletter-block form.contact-form').submit(function(e) { 
				var self = $(this);
        e.preventDefault(); 
        grecaptcha.ready(function() {
          grecaptcha.execute('6LchSLkqAAAAABVHBpeFgg8N-WgkYsr5fO6GUF_s', {action: 'submit'}).then(function(token) {
            self.find('input[name="g-recaptcha-response"]').val(token);
            $.ajax({
              type: 'POST',
              url:'/account/contact',
              data: $('.newsletter-form form.contact-form').serialize(),
              complete:function(data){	
                $('.rst_newsletter-block .newsletter-error').html('');
                swal({
                  icon: "success",
                  className: "newsletter-form-success",
                  title: "Đăng kí thông tin thành công",
                  text: "Thông báo sẽ tự động tắt sau 5 giây...",
                  button: false,
                  timer: 5000,
                });
                e.target.reset();
              }	
            })
          }); 
        });
			});
		}
  }
};
$(document).ready(function(){
	RST.Footer.newsletter.init();
});





